*.mkv
*.webm
*.mov
*.mp3
*.wav
*.flac
*.m4a
*.ogg
*.oga

# Node / tooling
node_modules/
dist/
build/
.env
.env.local

# Personal preferences — NEVER commit this in the public template repo.
# If you fork Sunday for your own use, remove this line so your prefs get tracked
# in YOUR private fork.
docs/personal-preferences.md

# Local secrets that scripts may read
.telegram-bot-token
.telegram-bot-allowed-ids
